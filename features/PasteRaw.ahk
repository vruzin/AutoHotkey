; ============================================================
; features/PasteRaw.ahk — вставка без форматирования (AHK v2)
;
; Большинство приложений вставляют RTF/HTML-форматирование, если оно
; есть в буфере (например, при копировании из браузера). PasteRaw
; пересохраняет ТОЛЬКО текстовую часть и вставляет её, теряя стили.
; ============================================================

class PuntoPasteRaw {
    static Paste() {
        ; Сохраняем оригинальный буфер
        bak := ClipboardAll()
        ; Получаем только текст
        text := A_Clipboard
        if (text = "") {
            ; Если в буфере нет текстовых данных — ничего не делаем
            A_Clipboard := bak
            return
        }
        A_Clipboard := text       ; кладём чисто текст обратно
        ClipWait(0.3)
        Send "^v"
        Sleep 80
        A_Clipboard := bak        ; восстанавливаем оригинал
    }
}
